# ============================================================
# SmartNexus — Environment Variables
# Kopyala → .env olarak kaydet, değerleri doldur
# ============================================================

# --- DATABASE (Neon / Supabase / Railway PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASS@HOST:5432/smartnexus?sslmode=require"

# --- JWT ---
JWT_SECRET="buraya-cok-uzun-gizli-bir-key-yaz-min-32-karakter"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="buraya-baska-gizli-bir-key-yaz"
JWT_REFRESH_EXPIRES_IN="30d"

# --- API ---
API_PORT=3001
API_PREFIX=api
NODE_ENV=production

# --- CORS: Vercel URL (deploy sonrası güncelle) ---
FRONTEND_URL=https://smartnexus.vercel.app

# --- AI Asistan (Vercel AI Gateway, OpenAI veya yerel Ollama) ---
# Vercel deploy: AI_GATEWAY_API_KEY otomatik gelir
# Panelden sağlayıcı seçebilirsiniz: Nexus Admin → Nexus Asistan
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
AI_CHAT_MODEL=openai/gpt-4o-mini
# Ollama (yerel, API anahtarı gerekmez): ollama serve + ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- E-Fatura (Uyumsoft SOAP) ---
EINVOICE_PROVIDER=uyumsoft
UYUMSOFT_API_URL=https://efatura-test.uyumsoft.com.tr/services/BasicIntegration
UYUMSOFT_USERNAME=
UYUMSOFT_PASSWORD=
UYUMSOFT_VKN=
UYUMSOFT_SUPPLIER_NAME=SmartNexus Demo A.Ş.
UYUMSOFT_TAX_OFFICE=

# --- Open Banking (BKM ÖHVPS) ---
OPEN_BANKING_API_URL=https://api.bkm.com.tr/ohvps/sandbox/v1
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
OPEN_BANKING_REDIRECT_URI=http://localhost:3000/settings?tab=integrations

# --- Ödeme Gateway ---
PAYMENT_PROVIDER=iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
# Demo/test: ödeme PayTR'ye gitmeden otomatik onaylanır (canlıda false yapın)
PAYMENT_AUTO_APPROVE=true

# --- SMS (Netgsm) ---
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=SMARTNEXUS

# --- E-posta (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
