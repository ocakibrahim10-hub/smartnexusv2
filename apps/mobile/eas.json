{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://smartnexusv2.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://smartnexus-api.onrender.com/api"
      }
    },
    "production": {
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://smartnexusv2.vercel.app",
        "EXPO_PUBLIC_API_URL": "https://smartnexus-api.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
