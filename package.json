{
  "name": "smartnexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "start": "concurrently \"npm run start:prod --workspace=apps/api\" \"npm run start --workspace=apps/web\"",
    "restart": "node scripts/restart-servers.js",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,json}\" \"scripts/**/*.js\" \"*.md\"",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:seed": "npm run prisma:seed --workspace=apps/api",
    "db:studio": "npm run prisma:studio --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
